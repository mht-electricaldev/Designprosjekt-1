import numpy as np
import matplotlib.pyplot as plt
import csv

header = []
data1 = []
filename1 = 'Amax final version.csv'

with open(filename1) as csvfile:
    csvreader = csv.reader(csvfile)

    header = next(csvreader)

    for datapoint in csvreader:
        values = [float(value) for value in datapoint]
        data1.append(values)

time = [(p[0]) for p in data1]
ch1 = [(p[1]) for p in data1]
ch2 = [(p[2]) for p in data1]
m = 10**3
ch2 = [i*m for i in ch2]
time = [i*m for i in time]


plt.plot(time, ch2, label="$A_{max}v_1(t)$", color="y")
plt.grid(True)
plt.xticks([-2,-1,0,1,2])
plt.yticks([-50, -25, 0, 25, 50])
