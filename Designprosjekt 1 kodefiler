import numpy as np
import matplotlib.pyplot as plt

def x_1(x):
    return np.sin(2*np.pi*x)

inngangsSignal = x_1(1)
AMax = x_1(0.2)
AMin = x_1(0.8)

x_verdier = np.linspace(-1, 2, 1000)

plt.plot(x_verdier, x_1(x_verdier), color="r", label = "$v_1(t)$")
plt.plot(x_verdier, 0.2*x_1(x_verdier), color="y", label = "$A_{max}v_1(t)$")
plt.plot(x_verdier, 0.7*x_1(x_verdier), color="C1", label = "$A_{min}v_1(t)$")
plt.xlabel("Tid [s]", fontsize=12)
plt.ylabel("Spenning [V]", fontsize=12)
plt.title("Ønsket oppførsel på nivåregulatoren sett i oscilloskop", fontsize=14)
plt.xticks([-1, 0, 1, 2])
plt.yticks([-1, -0.5, 0, 0.5, 1])
plt.legend(fontsize=12)
plt.savefig("Ønsket oppførsel")

