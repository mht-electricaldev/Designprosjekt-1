import numpy as np
import matplotlib.pyplot as plt

def A_min1(x):
    return x**2-x

def A_min2(x):
    return -x**2+2*x-1

xVerdier = np.linspace(0,1,1000)

yVerdier1 = A_min1(xVerdier)
yVerdier2 = A_min2(xVerdier)

plt.plot(xVerdier, yVerdier1, label="A: $A_{min}^2-A_{min}$")
plt.plot(xVerdier, yVerdier2, label="B: $-A_{min}^2+2A_{min}-1$")
plt.title("Evaluering av $R_2$ i konfigurasjon A og B")
plt.plot(0.5,-0.25, 'o')
plt.annotate("Krysningspunkt (0.5, -0.25)", (0.5, -0.325))
plt.xlabel("Verdier for $A_{min}$", fontsize = 12)
plt.xticks([0,0.5,1])
plt.ylabel("Uttrykkets verdi", fontsize=12)
plt.yticks([-1, -0.5, 0])
plt.legend()
plt.savefig("Evaluering av A_min")

